---
const defaultNavItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Catálogo', href: '/catalogo' },
  { name: 'Dirección', blank: true, href: 'https://www.google.com/maps/place/MHE+indumentaria+Mayorista/@-33.1262169,-64.3419488,19z/data=!3m1!4b1!4m22!1m15!4m14!1m6!1m2!1s0x95d20008e1332ec5:0xb8896c87f6afadbb!2sV%C3%A9lez+Sarsfield+756,+X5800+R%C3%ADo+Cuarto,+C%C3%B3rdoba,+Argentina!2m2!1d-64.3413051!2d-33.126218!1m6!1m2!1s0x95d201002a9baa7d:0x8952ac237037d63e!2sMHE+indumentaria+Mayorista,+V%C3%A9lez+Sarsfield+756,+X5800+R%C3%ADo+Cuarto,+C%C3%B3rdoba!2m2!1d-64.3412952!2d-33.1261892!3m5!1s0x95d201002a9baa7d:0x8952ac237037d63e!8m2!3d-33.126218!4d-64.3413051!16s%2Fg%2F11zbqb0dn4?entry=ttu&g_ep=EgoyMDI2MDUyNy4wIKXMDSoASAFQAw%3D%3D' },
]
const props = Astro.props
const { navItems = defaultNavItems } = props
---
<header data-mobile-nav class="sticky top-0 z-20 flex items-center justify-between border-b border-[#3a3e3e] bg-[rgb(10_12_12/82%)] px-[clamp(1.25rem,2.6vw,3.5rem)] py-[1.1rem] backdrop-blur-[10px]">
  <div class="flex items-center gap-4">
    <a href="/" class="flex items-center gap-2">
      <img src="/logos/MHE-08.svg" alt="MHE Logo" class="h-6 w-auto" />
    </a>
  </div>
  <button
    type="button"
    data-mobile-nav-toggle
    aria-label="Abrir menu"
    aria-controls="mobile-nav-menu"
    aria-expanded="false"
    class="flex md:hidden h-10 w-10 items-center justify-center rounded-md border border-[#3a3e3e] text-[#eceeee]"
  >
    <span class="sr-only">Abrir menu</span>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5">
      <path d="M4 7h16" stroke-linecap="round"></path>
      <path d="M4 12h16" stroke-linecap="round"></path>
      <path d="M4 17h16" stroke-linecap="round"></path>
    </svg>
  </button>
  <nav class="hidden gap-[clamp(0.6rem,1vw,1.8rem)] md:flex">
    {
      navItems.map((item :{ name: string, href: string, blank?: boolean }) => (
        <a
          href={item.href}
          target={item.blank ? "_blank" : "_self"}
          rel={item.blank ? "noopener noreferrer" : undefined}
          class='border px-[0.5rem] py-[0.4rem] text-[0.74rem] tracking-[0.14em] transition duration-200 border-transparent text-[#b6b9b9] hover:border-[#eceeee] hover:text-[#eceeee]'
        >
          {item.name.toUpperCase()}
        </a>
      ))
    }
  </nav>
  <div id="mobile-nav-menu" data-mobile-nav-menu class="invisible absolute right-0 top-full -translate-y-2 px-[clamp(1.25rem,2.6vw,3.5rem)] pb-4 opacity-0 pointer-events-none transition-all duration-200 ease-out md:hidden">
    <nav class="rounded-md border border-[#3a3e3e] bg-[rgb(10_12_12/96%)] p-2 backdrop-blur-[10px]">
      {
        navItems.map((item :{ name: string, href: string, blank?: boolean }) => (
          <a
            href={item.href}
            target={item.blank ? "_blank" : "_self"}
            rel={item.blank ? "noopener noreferrer" : undefined}
            class='block rounded-[0.35rem] border border-transparent px-3 py-[0.65rem] text-[0.74rem] tracking-[0.14em] text-[#b6b9b9] transition duration-200 hover:border-[#eceeee] hover:text-[#eceeee]'
          >
            {item.name.toUpperCase()}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const headerSelector = '[data-mobile-nav]'
  const readyAttr = 'data-mobile-nav-ready'
  const initializedHeaders = new WeakSet()

  const closeAllMenus = () => {
    document.querySelectorAll(headerSelector).forEach((header) => {
      const toggle = header.querySelector('[data-mobile-nav-toggle]')
      const menu = header.querySelector('[data-mobile-nav-menu]')
      if (!toggle || !menu) return

      toggle.setAttribute('aria-expanded', 'false')
      menu.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto')
      menu.classList.add('opacity-0', '-translate-y-2', 'pointer-events-none')

      window.setTimeout(() => {
        if (toggle.getAttribute('aria-expanded') === 'false') {
          menu.classList.add('invisible')
        }
      }, 200)
    })
  }

  const initMobileNav = () => {
    const headers = document.querySelectorAll(headerSelector)

    headers.forEach((header) => {
      if (initializedHeaders.has(header)) return

      const toggle = header.querySelector('[data-mobile-nav-toggle]')
      const menu = header.querySelector('[data-mobile-nav-menu]')
      if (!toggle || !menu) return

      toggle.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true'
        if (!isOpen) closeAllMenus()

        toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true')
        if (isOpen) {
          menu.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto')
          menu.classList.add('opacity-0', '-translate-y-2', 'pointer-events-none')

          window.setTimeout(() => {
            if (toggle.getAttribute('aria-expanded') === 'false') {
              menu.classList.add('invisible')
            }
          }, 200)
        } else {
          menu.classList.remove('invisible', 'opacity-0', '-translate-y-2', 'pointer-events-none')
          menu.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto')
        }
      })

      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => closeAllMenus())
      })

      initializedHeaders.add(header)
    })
  }

  if (!document.documentElement.hasAttribute(readyAttr)) {
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeAllMenus()
    })

    document.addEventListener('click', (event) => {
      const target = event.target
      if (!(target instanceof Node)) return
      if (!target.parentElement?.closest(headerSelector)) closeAllMenus()
    })

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) closeAllMenus()
    })

    document.addEventListener('astro:page-load', () => {
      initMobileNav()
      closeAllMenus()
    })

    document.documentElement.setAttribute(readyAttr, 'true')
  }

  initMobileNav()
</script>