---
import Layout from '../layouts/Layout.astro';
import IconBrandInstagram from '@tabler/icons/outline/brand-instagram.svg';
import IconBrandWhatsapp from '@tabler/icons/outline/brand-whatsapp.svg';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const values = [
	{
		number: '01',
		title: 'Calidad que responde.',
		description:
			'Excelencia técnica en cada costura. Priorizamos la estructura y la terminación para que cada prenda dure.'
	},
	{
		number: '02',
		title: 'Entrega que cumple.',
		description:
			'El tiempo es clave para cada lanzamiento. Organizamos la producción para respetar fechas y compromisos reales.'
	},
	{
		number: '03',
		title: 'Precio que conviene.',
		description:
			'Escala mayorista, procesos eficientes y costos claros para sostener volumen sin resignar calidad.'
	}
];
---

<Layout
	title="MHE | Fabrica de Indumentaria Mayorista en Rio Cuarto"
	description="MHE fabrica indumentaria mayorista personalizada en Rio Cuarto. Produccion textil para marcas y empresas con calidad, escala y tiempos de entrega concretos."
	image="/logos/MHE-06.svg"
	keywords={['fabrica de indumentaria', 'indumentaria mayorista', 'ropa personalizada', 'fabricacion textil', 'Rio Cuarto']}
	type="website"
>
	<Header />

	<main class="grid gap-32 pb-16">
		<h1 class="sr-only">MHE fabrica de indumentaria mayorista en Rio Cuarto</h1>
		<section class="relative min-h-screen overflow-hidden border-b border-[#3a3e3e] md:mt-0">
			<div class="anim-industry pointer-events-none absolute -left-[2vw] top-[14%] hidden select-none font-['Montserrat'] text-[clamp(7rem,21vw,24rem)] font-black leading-none  text-transparent [--stroke-color:rgb(236_238_238_/_0.08)] [text-shadow:0_0_1px_rgb(236_238_238_/_0.08)] [-webkit-text-stroke:1px_var(--stroke-color)] lg:block">INDUSTRY</div>
			<div class="absolute inset-0 bg-gradient-to-r from-[rgb(10_11_11_/_92%)] via-[rgb(10_11_11_/_56%)] to-[rgb(10_11_11_/_82%)]"></div>
			<!-- <div class="absolute inset-0 bg-[linear-gradient(90deg,transparent_0,transparent_70px,rgb(255_255_255_/_0.02)_70px,rgb(255_255_255_/_0.02)_71px)]"></div> -->

			<div class="relative z-10 mx-auto grid min-h-screen w-full max-w-[1600px] items-center gap-8 px-[clamp(1.25rem,2.6vw,3.5rem)] py-16 lg:grid-cols-12 lg:py-10">
				<div class="grid content-center lg:col-span-7 lg:max-w-[44rem]">
					<span class="anim-hero-tag mb-[1.35rem] inline-block border border-[#3a3e3e] bg-[rgb(15_17_17/75%)] px-[0.8rem] py-[0.5rem] text-[0.71rem] tracking-[0.18em]">EST. 2026 / RÍO CUARTO</span>
					<p class="anim-hero-sub text-[0.74rem] tracking-[0.12em] text-[#b6b9b9] uppercase">Nuevos en el mercado. No en la industria.</p>
					<!-- <h2 class="m-0 my-[0.35rem] mb-[1.2rem] font-['Montserrat'] text-[clamp(3rem,13vw,9rem)] leading-[0.9] font-black tracking-[-0.06em]">M·H·E</h2> -->
					<img src="/logos/MHE-08.svg" alt="MHE Logo" class="anim-hero-logo my-2 h-25 sm:h-auto w-auto sm:w-full" />
					<p class="anim-hero-desc max-w-[40ch] text-[clamp(1rem,2vw,1.2rem)] leading-7 text-[#d4d8d8]">Fabricamos indumentaria personalizada para marcas, empresas y proyectos que necesitan escala, calidad y tiempos concretos.</p>
					<div class="anim-hero-cta mt-7 flex flex-wrap gap-[0.9rem]">
						<a href="https://wa.me/message/NP3LEHH52CPMG1" target="_blank" class="border border-[#eceeee] bg-[#eceeee] px-[1.3rem] py-[0.82rem] text-[0.74rem] tracking-[0.14em] text-[#0c0d0d] uppercase transition hover:bg-transparent hover:text-[#eceeee]">Contactar</a>
						<a href="/catalogo" class="border border-[#eceeee] px-[1.3rem] py-[0.82rem] text-[0.74rem] tracking-[0.14em] uppercase transition hover:bg-[#eceeee] hover:text-[#0c0d0d]">Catalogo</a>
					</div>
				</div>

				<div class="lg:col-span-5 lg:justify-self-end hover:shadow-[0_10px_40px_rgba(255,255,255,0.2)] transition duration-100" id="branding-card">
					<div class="anim-hero-panel group relative mx-auto w-full max-w-[560px] border border-[#3a3e3e] bg-[rgb(12_14_14_/_62%)] p-6 backdrop-blur-[2px] sm:p-8 lg:mx-0 lg:mr-0">
						<div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[rgb(255_255_255_/_0.03)]"></div>
						<div class="relative">
							<p class="mb-4 text-[0.66rem] tracking-[0.18em] text-[#8d9292] uppercase">Identidad visual</p>
							<img
								class="py-5 mx-auto w-3/4 max-w-[460px]"
								src="/logos/MHE-03.svg"
								alt="MHE Logo"
							/>
							<div class="mt-5 flex items-center justify-between border-t border-[#2d3232] pt-4 text-[0.67rem] tracking-[0.16em] text-[#9aa0a0] uppercase">
								<span>Fabricacion mayorista</span>
								<span>Calidad / Escala</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		

		<section class="grid gap-[clamp(2rem,4vw,6rem)] px-[clamp(1.25rem,2.6vw,3.5rem)] lg:grid-cols-[minmax(16rem,1fr)_minmax(18rem,2fr)]" id="servicios">
			<div data-anim="up">
				<span class="mb-4 inline-block border-b border-[#3a3e3e] pb-2 text-[0.7rem] tracking-[0.16em] text-[#b6b9b9]">VALORES // 01</span>
				<h3 class="m-0 font-['Montserrat'] text-[clamp(2rem,5vw,4rem)] leading-[0.94] font-extrabold uppercase">ENTENDEMOS LO QUE BUSCA EL CLIENTE.</h3>
			</div>
			<div class="grid gap-[1.35rem]">
				{
					values.map((value, i) => (
						<article data-anim="up" style={`--anim-delay: ${i * 160}ms`} class="border-l-2 border-[#3a3e3e] bg-gradient-to-r from-[rgb(255_255_255_/_2%)] to-transparent py-[0.4rem] pl-4">
							<span class="text-[0.7rem] tracking-[0.16em] text-[#b9bcbc]">{value.number} / MHE</span>
							<h4 class="mt-[0.35rem] font-['Montserrat'] text-[clamp(1.35rem,2.5vw,2rem)] uppercase">{value.title}</h4>
							<p class="mt-[0.52rem] max-w-[64ch] leading-[1.65] text-[#bdc0c0]">{value.description}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="relative overflow-hidden border-y border-[#3a3e3e] bg-white px-[clamp(1.25rem,2.6vw,3.5rem)] py-10 selection:bg-black selection:text-white">
			<div class="relative mx-auto flex flex-col gap-4 items-end z-10">
				<h3 data-anim="up" class="m-0 font-['Montserrat'] lg:text-5xl text-3xl leading-[0.92] font-extrabold text-[#333] text-nowrap uppercase">¿Quiénes somos?</h3>
				<p data-anim="up" style="--anim-delay: 120ms" class="m-0 lg:text-2xl text-xl font-bold tracking-[0.02em] text-[#333] uppercase">NO SOMOS OTRA FÁBRICA DE INDUMENTARIA.</p>
			</div>
			<div data-anim="expand-x" style="--anim-delay: 260ms" class="mx-auto my-8 h-px w-[clamp(170px,28vw,320px)] bg-[#333]"></div>
			<p data-anim="up" style="--anim-delay: 420ms" class="text-center mx-auto mt-8 font-['Montserrat'] lg:text-5xl text-3xl leading-[0.96] font-black italic text-[#333] uppercase z-10">
			 SOMOS LA <span class="text-white text-shadow-[-1px_-1px_0_#333,-1px_1px_0_#333,1px_1px_0_#333,1px_-1px_0_#333]">FU*KING</span> FÁBRICA DE INDUMENTARIA.
			</p>

			<img src="/logos/MHE-03-black.svg" alt="MHE Logo" class="absolute top-0 left-5 opacity-10 z-1" />
		</section>

		<section class="grid gap-[clamp(1.4rem,3vw,3rem)] px-[clamp(1.25rem,2.6vw,3.5rem)] lg:grid-cols-[1fr_auto_auto]" id="nosotros">
			<div data-anim="up" class="grid content-center gap-4 border border-[#3a3e3e] bg-[#171a1a] p-[clamp(1.5rem,4vw,3rem)]">
				<h3 class="m-0 font-['Montserrat'] text-[clamp(2rem,4.4vw,4rem)]">Hablemos</h3>
				<strong class="font-['Montserrat'] text-[clamp(1.1rem,2.3vw,2rem)] leading-[1.35] uppercase">SABEMOS LO QUE FUNCIONA. Y TAMBIÉN LO QUE NO.</strong>
				<p class="m-0 text-[#c6caca] tracking-[0.1em] uppercase">¿Creamos algo juntos?</p>

				<ul class="mt-4 flex gap-5 text-[#c6caca]">
					<li><a class="hover:text-white transition duration-200" href="https://www.instagram.com/mhe.mayorista?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank"><IconBrandInstagram /></a></li>
					<li><a class="hover:text-white transition duration-200" href="https://wa.me/message/NP3LEHH52CPMG1" target="_blank"><IconBrandWhatsapp /></a></li>
				</ul>
			</div>
			<div data-anim="up" style="--anim-delay: 150ms" class="group w-fit overflow-clip border border-[#3a3e3e] aspect-[9/16] mx-auto">
				<video class="lg:max-h-[80dvh] max-h-[80dvh] w-full" src="/video/MHE_LANZAMIENTO.mp4" autoplay loop muted playsinline preload="metadata" poster="/logos/MHE-03.svg"></video>
			</div>
			<div data-anim="up" style="--anim-delay: 300ms" class="hidden lg:block group w-fit overflow-clip border border-[#3a3e3e] aspect-[9/16] mx-auto filter-[sepia(100%)] relative">
				<video class="lg:max-h-[80dvh] max-h-[80dvh]" src="/video/MHE_LANZAMIENTO.mp4" autoplay loop muted playsinline preload="metadata" poster="/logos/MHE-03.svg"></video>
				<img src="/logos/MHE-04.svg" alt="" class="absolute inset-0 m-auto w-full bg-black/60" />
			</div>
		</section>
	</main>
	<Footer />
</Layout>
