---
import '@fontsource/montserrat/400.css';
import '@fontsource/montserrat/700.css';
import '@fontsource/montserrat/800.css';
import '@fontsource/montserrat/900.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	keywords?: string[];
	type?: 'website' | 'article' | 'product';
	noindex?: boolean;
	schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
	title = 'MHE | Mayorista de Indumentaria',
	description = 'Fabricacion mayorista de indumentaria personalizada, con foco en calidad, tiempos de entrega y precio competitivo.',
	image = '/logos/MHE-06.svg',
	keywords = ['indumentaria mayorista', 'fabrica textil', 'Rio Cuarto', 'ropa personalizada', 'proveedor mayorista'],
	type = 'website',
	noindex = false,
	schema
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? 'https://www.mhe-indumentaria.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const resolvedImage = image.startsWith('http')
	? image
	: new URL(image.startsWith('/') ? image : `/${image}`, siteUrl).toString();
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';

const defaultSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'MHE Indumentaria Mayorista',
	url: siteUrl,
	logo: new URL('/logos/MHE-06.svg', siteUrl).toString(),
	address: {
		'@type': 'PostalAddress',
		streetAddress: 'Velez Sarsfield 756',
		addressLocality: 'Rio Cuarto',
		addressRegion: 'Cordoba',
		postalCode: '5800',
		addressCountry: 'AR'
	}
};

const schemaPayload = schema ?? defaultSchema;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content={robotsContent} />
		<meta name="googlebot" content={robotsContent} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords.join(', ')} />
		<meta name="author" content="MHE Indumentaria Mayorista" />
		<meta name="theme-color" content="#0f1111" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />

		<!-- Open Graph -->
		<meta property="og:site_name" content="MHE Indumentaria Mayorista" />
		<meta property="og:locale" content="es_AR" />
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={resolvedImage} />
		<meta property="og:image:alt" content="MHE Indumentaria Mayorista" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedImage} />

		<meta name="generator" content={Astro.generator} />
		<script type="application/ld+json" set:html={JSON.stringify(schemaPayload)} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="min-h-screen bg-[radial-gradient(circle_at_20%_-10%,#303434_0%,#0f1111_48%)] text-[#eceeee] font-['JetBrains_Mono'] antialiased selection:bg-[#eceeee] selection:text-[#333]">
		<slot />
		<script>
			let revealObserver;
			let isClientNavigation = false;

			const initScrollReveal = (skipAnimation = false) => {
				revealObserver?.disconnect();

				if (skipAnimation) {
					document.querySelectorAll('[data-anim]').forEach((el) => el.classList.add('in-view'));
					return;
				}

				revealObserver = new IntersectionObserver(
					(entries) =>
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('in-view');
								revealObserver.unobserve(entry.target);
							}
						}),
					{ threshold: 0.1, rootMargin: '0px 0px -52px 0px' }
				);

				document
					.querySelectorAll('[data-anim]:not(.in-view)')
					.forEach((el) => revealObserver.observe(el));
			};

			const initBrandingTilt = () => {
				if (window.innerWidth < 1024) return;

				const card = document.getElementById('branding-card');
				if (!card || card.dataset.tiltReady === 'true') return;

				const width = card.clientWidth;
				const height = card.clientHeight;

				card.addEventListener('mousemove', (event) => {
					const { layerX, layerY } = event;
					const yRotation = ((layerX - width / 2) / width) * 20;
					const xRotation = ((layerY - height / 2) / height) * 20;

					card.style.transform = `
						perspective(1000px)
						scale(1.02)
						rotateX(${xRotation}deg)
						rotateY(${yRotation}deg)
					`;
				});

				card.addEventListener('mouseleave', () => {
					card.style.transform = 'perspective(500px) scale(1) rotateX(0) rotateY(0)';
				});

				card.dataset.tiltReady = 'true';
			};

			const initPageEffects = (skipRevealAnimation = false) => {
				initScrollReveal(skipRevealAnimation);
				initBrandingTilt();
			};

			document.addEventListener('astro:before-preparation', () => {
				isClientNavigation = true;
			});

			document.addEventListener('astro:page-load', () => {
				initPageEffects(isClientNavigation);
				isClientNavigation = false;
			});

			initPageEffects();
		</script>
	</body>
</html>
